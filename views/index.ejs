<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lynkly – Shorten Your Links Instantly</title>
    <meta name="description"
        content="Lynkly is a fast, modern URL shortener. Create short links, custom aliases, and track clicks.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">Lynkly</a>
            <div class="nav-links">
                <% if (typeof currentUser !=='undefined' && currentUser) { %>
                    <a href="/dashboard" class="nav-link">Dashboard</a>
                    <a href="/auth/logout" class="nav-link btn-outline-nav">Logout</a>
                    <% } else { %>
                        <a href="/auth/login" class="nav-link">Login</a>
                        <a href="/auth/register" class="nav-link btn-primary-nav">Sign Up</a>
                        <% } %>
            </div>
        </div>
    </nav>
    <!-- Hero Section -->
    <main class="hero">
        <div class="hero-content">
            <div class="hero-badge">Free & Open Source</div>
            <h1 class="hero-title">
                <span class="gradient-text">Linkly</span>
            </h1>
            <p class="hero-subtitle">
                Create short, memorable links in seconds. Use custom aliases, track every click, and manage all your
                URLs from one beautiful dashboard.
            </p>

            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
                <% } %>

                    <div class="hero-cta">
                        <% if (typeof currentUser !=='undefined' && currentUser) { %>
                            <a href="/dashboard" class="btn btn-primary btn-lg">Go to Dashboard →</a>
                            <% } else { %>
                                <a href="/auth/register" class="btn btn-primary btn-lg">Get Started Free →</a>
                                <a href="/auth/login" class="btn btn-ghost btn-lg">Login</a>
                                <% } %>
                    </div>
                    <!-- Feature pills -->
                    <div class="feature-pills">
                        <div class="pill">⚡ Instant Shortening</div>
                        <div class="pill">🗑️ Easy Management</div>
                    </div>
        </div>
        <!-- Decorative background elements -->
        <div class="hero-glow"></div>
    </main>
</body>
</html>