<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Lynkly - URL Shortener</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f2ef;
            font-family: Arial, sans-serif;
        }

        .main-card {
            width: 920px;
            padding: 45px;
            border-radius: 14px;
            background: #7a0c1e;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .title {
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #f1d7db;
            margin-bottom: 30px;
            font-size: 16px;
        }

        .form-control {
            border-radius: 8px;
        }

        .btn-primary {
            background: #f8b400;
            border: none;
            color: #000;
            font-weight: 600;
        }

        .btn-primary:hover {
            background: #e0a300;
        }
    </style>

</head>

<body>

    <div class="main-card text-center">

        <h2 class="title">🔗 Lynkly</h2>
        <p class="subtitle">Shorten your long URLs instantly</p>

        <form action="/shorten" method="POST" class="needs-validation" novalidate>
        
            <div class="input-group">
        
                <input type="url" name="originalUrl" class="form-control" placeholder="Paste your long URL here..." required>
        
                <button class="btn btn-primary">
                    Shorten
                </button>
        
                <div class="invalid-feedback">
                    Please enter a valid URL.
                </div>
        
            </div>
        
        </form>

    </div>

    <script>
        (() => {
            'use strict'

            const forms = document.querySelectorAll('.needs-validation')

            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {

                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }

                    form.classList.add('was-validated')

                }, false)
            })
        })();
    </script>
</body>

</html>