<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <title>Your Short URL</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f2ef;
            font-family: Arial, sans-serif;
        }

        .card-box {
            width: 520px;
            padding: 45px;
            border-radius: 14px;
            background: white;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
            text-align: center;
        }

        .short-url {
            font-size: 20px;
            font-weight: 600;
            margin: 20px 0;
            color: #7a0c1e;
            word-break: break-all;
        }

        .short-url a {
            text-decoration: none;
            color: #7a0c1e;
        }

        .short-url a:hover {
            text-decoration: underline;
        }
    </style>

</head>

<body>

    <div class="card-box">

        <h3 style="color:#7a0c1e;">Your Short URL is Ready</h3>

        <div class="short-url">
            <a href="<%= shortUrl %>">
                <%= shortUrl %>
            </a>
        </div>

        <div class="d-flex justify-content-center gap-3">

            <a href="/" class="btn btn-outline-dark">
                Shorten Another
            </a>

        </div>

    </div>

</body>

</html>